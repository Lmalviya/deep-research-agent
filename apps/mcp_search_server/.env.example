# MCP Search Server — Environment Variables
# Copy this file to .env and fill in your values.
# .env should never be committed to version control.

# URL of your self-hosted SearxNG instance
SEARXNG_BASE_URL=http://localhost:8080

# HTTP request timeout in seconds (applies to all outbound calls)
REQUEST_TIMEOUT=30

# Maximum search results returned per search() call
MAX_SEARCH_RESULTS=5

# Maximum pages the crawler will visit per crawl() call
MAX_CRAWL_PAGES=20

# Number of pages to fetch in parallel per crawler wave
CRAWL_BATCH_SIZE=5

# Redis connection (used for search + extract caching)
REDIS_HOST=localhost
REDIS_PORT=6379

# ---
# MCP Transport
#
# stdio  → server communicates via stdin/stdout pipes.
#          Used by Claude Desktop and MCP Inspector (local dev).
#          The client spawns the server as a subprocess.
#
# sse    → server listens on a network port using Server-Sent Events.
#          Use this for Docker / containerized / multi-agent deployments
#          where the client connects over the network.
# ---
MCP_TRANSPORT=stdio

# Only required when MCP_TRANSPORT=sse:
MCP_HOST=0.0.0.0
MCP_PORT=8000
