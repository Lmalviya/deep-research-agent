# 🔑 LiteLLM Master Key - Generate a strong random string (e.g., sk-admin-...)
LITELLM_MASTER_KEY="your-master-key-here"

# 🧂 LiteLLM Salt Key - Generate a strong random string (do not change after setup)
LITELLM_SALT_KEY="your-salt-key-here"

# 💾 Database Configuration
LITELLM_DB_NAME=litellm
LITELLM_DB_USERNAME=llmproxy
LITELLM_DB_PASSWORD=your-db-password-here

# 🔗 Full Database URL for LiteLLM
# Format: postgresql://<username>:<password>@litellm_db:5432/<db_name>
DATABASE_URL="postgresql://llmproxy:your-db-password-here@litellm_db:5432/litellm"

# 🤖 Provider Credentials
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."
NVIDIA_NIM_API_KEY="nvapi-..."
DEEPSEEK_API_KEY="sk-..."
